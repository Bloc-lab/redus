# Lokální vývoj: prázdná URL → relativní /api (Vite proxy na localhost:3000)
VITE_PUBLIC_CMS_API_URL=
# Tenant podle domény (produkce na Vercelu): bloclab.cz / www.bloclab.cz → BLOCLAB, ostatní (např. *.vercel.app) → REDUS
VITE_CMS_API_KEY_BLOCLAB=
VITE_CMS_API_KEY_REDUS=
# Volitelný jeden klíč pro lokální dev / zpětnou kompatibilitu
VITE_CMS_API_KEY=

# Volitelné: jiný cíl proxy než http://localhost:3000 (viz vite.config.ts)
# VITE_CMS_PROXY_TARGET=http://127.0.0.1:4000

# Produkce / přímé volání (bez koncového /)
# VITE_PUBLIC_CMS_API_URL=https://api.example.com
#
# Veřejný náhled z administrace: web může mít v URL ?previewToken=…&lang=cs —
# frontend je předává v /api/v1/content a /api/v1/public/site-settings (+ X-API-KEY).
# Token z query se dočasně uloží do sessionStorage kvůli navigaci v SPA.

# Alternativní názvy: VITE_API_URL, PUBLIC_CMS_API_URL, PUBLIC_CMS_API_KEY
